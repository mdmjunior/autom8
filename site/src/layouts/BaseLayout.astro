---
import '../styles/global.css';

const {
  title = 'AutoM8 · Automação Linux para todos',
  description = 'AutoM8 é uma suíte gratuita e open source para automatizar instalações, configurações e tarefas no Linux desktop.'
} = Astro.props;

const nav = [
  ['Início', '/'],
  ['Módulos', '/modules'],
  ['Perfis', '/profiles'],
  ['Docs', '/docs'],
  ['Roadmap', '/roadmap'],
  ['Changelog', '/changelog'],
  ['GitHub', 'https://github.com/mdmjunior/autom8'],
  ['Instalar', '/install']
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0B1220" />
    <link rel="icon" type="image/svg+xml" href="/branding/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>

  <body>
    <header class="sticky top-0 z-40 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="site-brand-image" aria-label="AutoM8">
          <img
            src="/branding/logo-autom8-site.png"
            alt="AutoM8"
            class="site-brand-image__logo"
          />
        </a>

        <nav class="hidden items-center gap-5 text-sm font-semibold text-slate-300 lg:flex">
          {nav.map(([label, href]) => (
            <a
              href={href}
              class={label === 'Instalar'
                ? 'rounded-xl bg-blue-600 px-4 py-2 text-white shadow-lg shadow-blue-950/40 transition hover:bg-blue-500'
                : 'transition hover:text-blue-300'}
              target={href.startsWith('http') ? '_blank' : undefined}
              rel={href.startsWith('http') ? 'noreferrer' : undefined}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-slate-800 px-6 py-10 text-center text-sm text-slate-500">
      <div class="mx-auto max-w-7xl">
        <p class="font-semibold text-slate-300">AutoM8 by OSLabs</p>
        <p class="mt-2">Criado por Marcio Moreira Junior para a comunidade Linux.</p>
        <p class="mt-2 text-slate-600">Automação Linux para todos. Configure menos. Produza mais.</p>
      </div>
    </footer>
  </body>
</html>
