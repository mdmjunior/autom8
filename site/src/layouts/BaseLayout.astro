---
import '../styles/global.css';

const {
  title = 'AutoM8 · Automação Linux para todos',
  description = 'AutoM8 é uma suíte gratuita e open source para automatizar instalações, configurações e tarefas no Linux desktop.'
} = Astro.props;

const nav = [
  ['Início', '/'],
  ['Módulos', '/modules'],
  ['Perfis', '/profiles'],
  ['Docs', '/docs'],
  ['Roadmap', '/roadmap'],
  ['Changelog', '/changelog'],
  ['GitHub', 'https://github.com/mdmjunior/autom8'],
  ['Instalar', '/install']
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0B1220" />
    <link rel="icon" type="image/png" href="/branding/favicon.png?v=20260707" />
    <link rel="apple-touch-icon" href="/branding/favicon.png?v=20260707" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>

  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-brand-image" aria-label="AutoM8">
          <img
            src="/branding/logo-autom8-site.png?v=20260707"
            alt="AutoM8"
            class="site-brand-image__logo"
          />
        </a>

        <nav class="site-nav" aria-label="Navegação principal">
          {nav.map(([label, href]) => (
            <a
              href={href}
              class={label === 'Instalar' ? 'autom8-nav-install' : 'autom8-nav-link'}
              target={href.startsWith('http') ? '_blank' : undefined}
              rel={href.startsWith('http') ? 'noreferrer' : undefined}
            >
              {label}
            </a>
          ))}
        </nav>

        <a href="/install" class="autom8-mobile-install">
          Instalar
        </a>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="site-footer__brand">AutoM8 by OSLabs</p>
        <p class="site-footer__text">Criado por Marcio Moreira Junior para a comunidade Linux.</p>
        <p class="site-footer__tagline">Automação Linux para todos. Configure menos. Produza mais.</p>
      </div>
    </footer>
  </body>
</html>
