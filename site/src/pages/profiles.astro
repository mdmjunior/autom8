---
import BaseLayout from '../layouts/BaseLayout.astro';
import profiles from '../data/profiles.json';
---

<BaseLayout title="Perfis · AutoM8">
  <section class="px-6 py-20">
    <div class="mx-auto max-w-7xl">
      <h1 class="text-4xl font-black text-white">Perfis</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
        Perfis ajudam o usuário a preparar o sistema de acordo com seu uso, com modo mínimo seguro ou completo.
      </p>

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {profiles.map((item) => (
          <article class="rounded-2xl border border-slate-700/80 bg-slate-900/50 p-6">
            <h2 class="text-xl font-bold text-white">{item.name}</h2>
            <p class="mt-3 leading-7 text-slate-400">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
