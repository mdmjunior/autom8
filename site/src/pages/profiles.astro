---
import BaseLayout from '../layouts/BaseLayout.astro';
import profiles from '../data/profiles.json';
---

<BaseLayout
  title="Perfis · AutoM8"
  description="Perfis do AutoM8 para preparar ambientes Linux de acordo com o tipo de uso."
>
  <section class="site-page-hero">
    <div class="site-page-hero__inner">
      <p class="page-eyebrow">Perfis</p>
      <h1 class="page-title">Prepare o sistema conforme o uso.</h1>
      <p class="page-description">
        Perfis ajudam usuários iniciantes e avançados a configurar o Linux com escolhas mais rápidas, revisáveis e organizadas.
      </p>
    </div>
  </section>

  <section class="site-page-section">
    <div class="site-page-section__inner">
      <div class="section-heading">
        <p class="section-eyebrow text-blue-300">Ambientes</p>
        <h2>Perfis previstos</h2>
        <p>A proposta é permitir modo mínimo seguro ou completo, sempre deixando claro o que será instalado ou alterado.</p>
      </div>

      <div class="autom8-content-grid autom8-content-grid--three">
        {profiles.map((item) => (
          <article class="autom8-standard-card">
            <span class="autom8-card-kicker">perfil</span>
            <h3>{item.name}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
