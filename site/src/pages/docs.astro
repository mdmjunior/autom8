---
import BaseLayout from '../layouts/BaseLayout.astro';
import docs from '../data/docs.json';
---

<BaseLayout title="Docs · AutoM8">
  <section class="px-6 py-20">
    <div class="mx-auto max-w-7xl">
      <h1 class="text-4xl font-black text-white">Documentação inicial</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
        Comandos principais da primeira versão da suíte.
      </p>

      <div class="mt-10 overflow-hidden rounded-2xl border border-slate-700">
        <table class="w-full border-collapse text-left">
          <thead class="bg-slate-900">
            <tr>
              <th class="px-5 py-4 text-sm uppercase tracking-widest text-blue-300">Comando</th>
              <th class="px-5 py-4 text-sm uppercase tracking-widest text-blue-300">Descrição</th>
            </tr>
          </thead>
          <tbody>
            {docs.map((item) => (
              <tr class="border-t border-slate-800 bg-slate-950/40">
                <td class="px-5 py-4 font-mono text-sm text-blue-100">{item.command}</td>
                <td class="px-5 py-4 text-slate-300">{item.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>
