---
import BaseLayout from '../layouts/BaseLayout.astro';
import modules from '../data/modules.json';
---

<BaseLayout>
  <section class="px-6 py-24">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-2">
      <div>
        <div class="mb-5 inline-flex rounded-full border border-blue-400/30 bg-blue-500/10 px-4 py-2 text-sm text-blue-200">
          OSLabs · Linux automation toolkit
        </div>

        <h1 class="max-w-3xl text-5xl font-black leading-tight tracking-tight text-white md:text-6xl">
          AutoM8 - Linux Management Suite
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
          Uma suíte local para atualizar, limpar, diagnosticar, configurar e preparar estações Linux com perfis inteligentes e uma CLI moderna.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="/install" class="rounded-xl bg-blue-500 px-6 py-3 text-center font-bold text-white transition hover:bg-blue-400">
            Instalar agora
          </a>
          <a href="/docs" class="rounded-xl border border-slate-600 px-6 py-3 text-center font-bold text-slate-200 transition hover:border-blue-400 hover:text-blue-200">
            Ver comandos
          </a>
        </div>

        <div class="mt-8 rounded-2xl border border-slate-700 bg-slate-950/60 p-4 font-mono text-sm text-blue-100">
          curl -fsSL https://autom8.oslabs.com.br/install.sh | bash
        </div>
      </div>

      <div class="code-window rounded-3xl p-6 font-mono text-sm">
        <div class="mb-5 flex gap-2">
          <span class="h-3 w-3 rounded-full bg-red-400"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
          <span class="h-3 w-3 rounded-full bg-green-400"></span>
        </div>

        <p class="terminal-line text-slate-200">autom8 diagnose</p>
        <p class="terminal-output mt-2">Gerando relatório do sistema...</p>
        <p class="terminal-output">Docker: ativo · Firewall: ativo · Updates: 12</p>

        <p class="terminal-line mt-6 text-slate-200">autom8 clean --dry-run</p>
        <p class="terminal-output mt-2">Simulando limpeza segura...</p>
        <p class="terminal-output">Caches protegidos: browsers, projetos e arquivos recentes</p>

        <p class="terminal-line mt-6 text-slate-200">autom8 profiles</p>
        <p class="terminal-output mt-2">Perfis disponíveis: DevOps, Desenvolvedor, Gamer, Designer...</p>
      </div>
    </div>
  </section>

  <section class="px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 flex items-end justify-between gap-6">
        <div>
          <h2 class="text-3xl font-black text-white">Módulos principais</h2>
          <p class="mt-3 max-w-2xl text-slate-400">
            A v0.1.0 começa com base sólida e evolui para uma suíte completa.
          </p>
        </div>
        <a href="/modules" class="hidden text-sm font-bold text-blue-300 hover:text-blue-200 md:block">
          Ver todos
        </a>
      </div>

      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {modules.slice(0, 6).map((item) => (
          <article class="rounded-2xl border border-slate-700/80 bg-slate-900/50 p-6">
            <h3 class="text-xl font-bold text-white">{item.name}</h3>
            <p class="mt-3 leading-7 text-slate-400">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-16">
    <div class="mx-auto max-w-7xl rounded-3xl border border-blue-400/20 bg-blue-500/10 p-8 md:p-12">
      <h2 class="text-3xl font-black text-white">Distros oficialmente planejadas</h2>
      <div class="mt-6 flex flex-wrap gap-3 text-sm font-bold text-blue-100">
        {['Ubuntu', 'Debian', 'Fedora', 'Rocky Linux', 'AlmaLinux', 'openSUSE', 'Arch Linux', 'Manjaro'].map((distro) => (
          <span class="rounded-full border border-blue-300/30 bg-slate-950/40 px-4 py-2">{distro}</span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
