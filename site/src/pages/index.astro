---
import BaseLayout from '../layouts/BaseLayout.astro';
import modules from '../data/modules.json';
import terminalSessions from '../data/terminal-sessions.json';
import catalogSummary from '../data/catalog-summary.json';
import documentation from '../data/documentation.json';




const product = documentation.product;

const productStats = [
  {
    value: `v${catalogSummary.version}`,
    label: 'Versão estável',
    icon: 'version',
    tone: 'blue'
  },
  {
    value: catalogSummary.appsCount,
    label: 'Aplicativos',
    icon: 'apps',
    tone: 'green'
  },
  {
    value: catalogSummary.categories.length,
    label: 'Categorias',
    icon: 'categories',
    tone: 'violet'
  },
  {
    value: catalogSummary.profilesCount,
    label: 'Perfis',
    icon: 'profiles',
    tone: 'amber'
  }
];

const distros = [
  {
    name: 'Fedora',
    slug: 'fedora'
  },
  {
    name: 'Ubuntu',
    slug: 'ubuntu'
  },
  {
    name: 'Red Hat',
    slug: 'redhat'
  },
  {
    name: 'Debian',
    slug: 'debian'
  }
];

const carouselItems = [
  {
    eyebrow: 'Como funciona',
    description: 'Escolha uma tarefa, revise as ações propostas e confirme somente quando estiver pronto para executar.',
    type: 'text',
    icon: 'workflow'
  },
  {
    eyebrow: 'Segurança e transparência',
    description: 'As operações permanecem locais, registradas em logs e protegidas por confirmações explícitas.',
    type: 'text',
    icon: 'shield'
  },
  {
    eyebrow: 'Para quem é',
    description: 'Uma experiência previsível para usuários de desktop, desenvolvedores e administradores Linux.',
    type: 'text',
    icon: 'audience'
  },
  {
    eyebrow: 'Compatibilidade',
    description: '',
    type: 'distroGroup',
    icon: 'linux',
    distros
