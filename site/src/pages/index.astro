---
import BaseLayout from '../layouts/BaseLayout.astro';
import modules from '../data/modules.json';
import terminalSessions from '../data/terminal-sessions.json';




const distros = [
  { name: 'Ubuntu', slug: 'ubuntu', status: 'Planejada' },
  { name: 'Debian', slug: 'debian', status: 'Planejada' },
  { name: 'Fedora', slug: 'fedora', status: 'Planejada' },
  { name: 'Rocky Linux', slug: 'rocky', status: 'Planejada' },
  { name: 'AlmaLinux', slug: 'alma', status: 'Planejada' },
  { name: 'openSUSE', slug: 'opensuse', status: 'Planejada' },
  { name: 'Arch Linux', slug: 'arch', status: 'Planejada' },
  { name: 'Manjaro', slug: 'manjaro', status: 'Planejada' }
];

const carouselItems = [
  {
    eyebrow: 'Como funciona',
    title: 'Escolha. Revise. Execute.',
    description: 'O AutoM8 automatiza o que é repetitivo sem esconder o processo. Você entende o que será executado antes de aplicar.',
    type: 'text',
    icon: '01'
  },
  {
    eyebrow: 'Segurança e transparência',
    title: 'Automação com controle.',
    description: 'O AutoM8 foi feito para evitar execução cega. A proposta é organizar tarefas, reduzir repetição e manter o usuário consciente.',
    type: 'text',
    icon: '02'
  },
  {
    eyebrow: 'Para quem é',
    title: 'Do iniciante ao usuário avançado.',
    description: 'Uma suíte para quem quer usar Linux com menos fricção e mais visibilidade.',
    type: 'text',
    icon: '03'
  },
  {
    eyebrow: 'Compatibilidade',
    title: '',
    description: '',
    type: 'distroGroup',
    icon: 'distros',
    distros
  }
];


const moduleIcons = {
  update: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4a8 8 0 0 1 7.75 6h-2.1A6 6 0 1 0 12 18a5.9 5.9 0 0 0 4.24-1.76l1.42 1.42A8 8 0 1 1 12 4Zm7 1v5h-5l1.9-1.9A5.95 5.95 0 0 0 12 6V4a7.95 7.95 0 0 1 5.31 2.04L19 4.35V5Z"/></svg>`,
  clean: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 3 4 14l6 6 11-11-6-6Zm0 2.83L18.17 9 10 17.17 6.83 14 15 5.83ZM4 20h16v2H4v-2Z"/></svg>`,
  apps: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z"/></svg>`,
  profiles: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5Z"/></svg>`,
  config: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19.14 12.94a7.5 7.5 0 0 0 .05-.94 7.5 7.5 0 0 0-.05-.94l2.03-1.58-1.92-3.32-2.39.96a7.3 7.3 0 0 0-1.62-.94L14.88 3h-3.76l-.36 3.18a7.3 7.3 0 0 0-1.62.94l-2.39-.96-1.92 3.32 2.03 1.58a7.5 7.5 0 0 0-.05.94c0 .32.02.63.05.94l-2.03 1.58 1.92 3.32 2.39-.96c.5.39 1.04.7 1.62.94l.36 3.18h3.76l.36-3.18a7.3 7.3 0 0 0 1.62-.94l2.39.96 1.92-3.32-2.03-1.58ZM13 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Z"/></svg>`,
  doctor: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 3h6v2h3a2 2 0 0 1 2 2v14H4V7a2 2 0 0 1 2-2h3V3Zm2 2h2V4h-2v1Zm-5 2v12h12V7H6Zm5 3h2v2h2v2h-2v2h-2v-2H9v-2h2v-2Z"/></svg>`,
  backup: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h11l3 3v13H5V4Zm2 2v12h10V8h-3V6H7Zm2 7h6v2H9v-2Zm0-4h4v2H9V9Z"/></svg>`,
  diagnose: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 3h4v2h-4V3ZM5 7h14v14H5V7Zm2 2v10h10V9H7Zm2 2h6v2H9v-2Zm0 4h4v2H9v-2Z"/></svg>`,
  security: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 20 5v6c0 5-3.4 9.4-8 11-4.6-1.6-8-6-8-11V5l8-3Zm0 2.2L6 6.45V11c0 3.85 2.42 7.28 6 8.82 3.58-1.54 6-4.97 6-8.82V6.45l-6-2.25Z"/></svg>`,
  docker: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 13h16a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4Zm2-5h3v3H6V8Zm4 0h3v3h-3V8Zm4 0h3v3h-3V8ZM8 4h3v3H8V4Zm4 0h3v3h-3V4Z"/></svg>`,
  users: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v1h12v-1c0-2.21-2.69-4-6-4Zm8-1a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2a5.8 5.8 0 0 0-2.2.43A4.57 4.57 0 0 1 17 19h4v-1c0-1.66-1.79-3-4-3Z"/></svg>`
};

---

<BaseLayout>
  <section class="modern-hero px-6 py-14 md:py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="hero-copy">
        <h1 class="max-w-4xl text-5xl font-black leading-[1.02] tracking-tight text-white md:text-7xl">
          Automatize tarefas Linux com clareza e controle.
        </h1>

        <p class="mt-7 max-w-2xl text-xl leading-9 text-slate-300">
          AutoM8 é uma suíte local para instalar, diagnosticar, limpar e preparar ambientes Linux sem esconder o que será executado.
        </p>

      </div>

      <div class="product-console-shell">
        <div class="product-console-glow"></div>

        <div class="product-console-header">
          <div class="flex items-center gap-2">
            <span class="console-dot bg-red-400"></span>
            <span class="console-dot bg-yellow-400"></span>
            <span class="console-dot bg-green-400"></span>
          </div>
          <span>user@linux: ~</span>
        </div>

        <div class="autom8-live-terminal" data-autom8-terminal>
          <div class="terminal-screen" data-terminal-screen></div>
        </div>

      </div>
    </div>
  </section>



  <section class="px-6 py-14">
    <div class="mx-auto max-w-7xl">
      <div class="home-carousel-header">
        <div>
          <p class="section-eyebrow text-blue-300">Visão geral</p>
          <h2 class="mt-3 text-4xl font-black tracking-tight text-white">Entenda o AutoM8 em poucos minutos.</h2>
        </div>

        <div class="home-carousel-controls">
          <button type="button" class="home-carousel-button" data-carousel-prev aria-label="Item anterior">
            ‹
          </button>
          <button type="button" class="home-carousel-button" data-carousel-next aria-label="Próximo item">
            ›
          </button>
        </div>
      </div>

      <div class="home-carousel" data-home-carousel>
        {carouselItems.map((item) => (
          <article class="home-carousel-card">
            <div class="home-carousel-card__top">
              {item.type === 'distroGroup' ? (
                <span class="home-carousel-card__number">OS</span>
              ) : (
                <span class="home-carousel-card__number">{item.icon}</span>
              )}

              <span class="home-carousel-card__eyebrow">{item.eyebrow}</span>
            </div>

            {item.type === 'distroGroup' ? (
              <div class="home-carousel-distro-icons">
                {item.distros.map((distro) => (
                  <img
                    src={`/branding/distros/${distro.slug}.svg`}
                    alt={`Ícone ${distro.name}`}
                    title={distro.name}
                  />
                ))}
              </div>
            ) : (
              <>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>


  <section class="px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="section-eyebrow text-green-300">Recursos</p>
          <h2 class="mt-3 text-4xl font-black tracking-tight text-white">Módulos principais</h2>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-400">
            Módulos independentes ajudam a manter o sistema organizado, com ações revisáveis e foco em segurança.
          </p>
        </div>
        <a href="/modules" class="modern-link">
          Ver todos
        </a>
      </div>

      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {modules.slice(0, 9).map((item) => (
          <article class="modern-module-card">
            <div class="module-card-top">
              <div class="module-icon" set:html={moduleIcons[item.slug] ?? moduleIcons.diagnose}></div>
              <div class="module-command">
                autom8 {item.slug}
              </div>
            </div>
            <h3 class="text-xl font-black text-white">{item.name}</h3>
            <p class="mt-3 leading-7 text-slate-400">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>









  <script>
    const carousel = document.querySelector('[data-home-carousel]');
    const prevButton = document.querySelector('[data-carousel-prev]');
    const nextButton = document.querySelector('[data-carousel-next]');

    if (carousel && prevButton && nextButton) {
      const getStep = () => {
        const card = carousel.querySelector('.home-carousel-card');
        if (!card) return 360;

        const styles = window.getComputedStyle(carousel);
        const gap = Number.parseFloat(styles.columnGap || styles.gap || '24');

        return card.getBoundingClientRect().width + gap;
      };

      prevButton.addEventListener('click', () => {
        carousel.scrollBy({ left: -getStep(), behavior: 'smooth' });
      });

      nextButton.addEventListener('click', () => {
        carousel.scrollBy({ left: getStep(), behavior: 'smooth' });
      });
    }
  </script>

  <script define:vars={{ terminalSessions }}>
    const screen = document.querySelector('[data-terminal-screen]');
    const sessions = terminalSessions;

    const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

    function addLine(text, type = 'plain') {
      const line = document.createElement('div');
      line.className = `live-terminal-line terminal-${type}`;
      line.textContent = text;
      screen.appendChild(line);
      screen.scrollTop = screen.scrollHeight;
    }

    async function typeCommand(command) {
      const line = document.createElement('div');
      line.className = 'live-terminal-line terminal-command-line';

      const prompt = document.createElement('span');
      prompt.className = 'terminal-prompt';
      prompt.textContent = 'user@linux:~$ ';

      const typed = document.createElement('span');
      typed.className = 'terminal-typed is-typing';

      line.appendChild(prompt);
      line.appendChild(typed);
      screen.appendChild(line);

      for (const char of command) {
        typed.textContent += char;
        await sleep(18 + Math.random() * 22);
      }

      typed.classList.remove('is-typing');
      screen.scrollTop = screen.scrollHeight;
    }

    async function runTerminal() {
      let index = 0;

      while (true) {
        const session = sessions[index % sessions.length];
        screen.innerHTML = '';

        await typeCommand(session.command);
        await sleep(350);

        for (const item of session.output) {
          addLine(item.text, item.type);
          await sleep(180);
        }

        await sleep(2600);
        index += 1;
      }
    }

    if (screen && Array.isArray(sessions)) {
      runTerminal();
    }
  </script>
</BaseLayout>
