---

<BaseLayout>
  <section class="modern-hero px-6 py-14 md:py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="hero-copy">
        <h1 class="max-w-4xl text-[2.25rem] font-black leading-[1.02] tracking-tight text-white md:text-[3.375rem]">
          Não perca mais tempo configurando seu Desktop.
        </h1>

        <p class="mt-7 max-w-2xl text-xl leading-9 text-slate-300">
          {product.summary}
        </p>

                <div class="hero-copy__actions">
  <div class="hero-actions">
            <a
              href="/docs"
              class="hero-action-button hero-action-button--primary"
            >
              <span
                class="hero-action-button__icon"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24">
                  <path d="M5 4.5h10a4 4 0 0 1 4 4V20H9a4 4 0 0 1-4-4V4.5Z"></path>
                  <path d="M9 20V8.5a4 4 0 0 1 4-4"></path>
                  <path d="M12 9h4"></path>
                  <path d="M12 13h4"></path>
                </svg>
              </span>

              <span>Documentação</span>

              <svg
                class="hero-action-button__arrow"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M5 12h14"></path>
                <path d="m14 7 5 5-5 5"></path>
              </svg>
            </a>

            <a
              href="https://github.com/mdmjunior/autom8"
              class="hero-action-button hero-action-button--secondary"
              target="_blank"
              rel="noreferrer"
            >
              <span
                class="hero-action-button__icon"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24">
                  <path d="M12 2.8a9.2 9.2 0 0 0-2.91 17.93c.46.08.63-.2.63-.44v-1.76c-2.57.56-3.11-1.09-3.11-1.09-.42-1.07-1.03-1.35-1.03-1.35-.84-.58.06-.57.06-.57.93.07 1.42.96 1.42.96.83 1.42 2.17 1.01 2.7.77.08-.6.32-1.01.59-1.24-2.05-.23-4.2-1.03-4.2-4.57 0-1.01.36-1.84.95-2.49-.1-.23-.41-1.18.09-2.45 0 0 .78-.25 2.53.95A8.8 8.8 0 0 1 12 7.14a8.8 8.8 0 0 1 2.31.31c1.75-1.2 2.53-.95 2.53-.95.5 1.27.19 2.22.09 2.45.59.65.95 1.48.95 2.49 0 3.55-2.16 4.33-4.21 4.56.33.29.62.85.62 1.71v2.58c0 .24.17.52.64.44A9.2 9.2 0 0 0 12 2.8Z"></path>
                </svg>
              </span>

              <span>GitHub</span>

              <svg
                class="hero-action-button__arrow"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M7 17 17 7"></path>
                <path d="M8 7h9v9"></path>
              </svg>
            </a>
          </div>


        </div>


      </div>

      <div class="product-console-shell">
        <div class="product-console-glow"></div>

        <div class="product-console-header">
          <div class="flex items-center gap-2">
            <span class="console-dot bg-red-400"></span>
            <span class="console-dot bg-yellow-400"></span>
            <span class="console-dot bg-green-400"></span>
          </div>
          <span>user@linux: ~</span>
        </div>

        <div class="autom8-live-terminal" data-autom8-terminal>
          <div class="terminal-screen" data-terminal-screen></div>
        </div>

      </div>
    </div>
  </section>

  <section
    class="product-stats-section px-6"
    aria-label="Estado atual do AutoM8"
  >
    <div class="product-stats mx-auto max-w-7xl">
      {productStats.map((stat) => (
        <article class="product-stat-card">
          <div
            class={`product-stat-icon product-stat-icon--${stat.tone}`}
            set:html={statIcons[stat.icon]}
          ></div>

          <div class="product-stat-content">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        </article>
      ))}
    </div>
  </section>



    <section class="px-6 py-14 home-info-section">
    <div class="mx-auto max-w-7xl">
      <div class="home-carousel-header">
        <h2 class="mt-3 text-[1.6875rem] font-black tracking-tight text-white">
          Entenda o AutoM8 em poucos minutos.
        </h2>
      </div>

      <div class="home-info-grid">
        {carouselItems.map((item) => (
          <article
            class:list={[
              'home-carousel-card',
              item.type === 'distroGroup' &&
                'home-carousel-card--compatibility'
            ]}
          >
            <div class="home-carousel-card__top">
              <div
                class={`home-carousel-card__icon home-carousel-card__icon--${item.icon}`}
                set:html={carouselIcons[item.icon]}
              ></div>

              <span class="home-carousel-card__eyebrow">
                {item.eyebrow}
              </span>
            </div>

            {item.type === 'distroGroup' ? (
              <div class="home-carousel-distro-icons">
                {item.distros.map((distro) => (
                  <img
                    src={`/branding/distros/${distro.slug}.svg`}
                    alt={`Distribuição ${distro.name}`}
                    title={distro.name}
                  />
                ))}
              </div>
            ) : (
              <p>{item.description}</p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>


  <section class="px-6 py-16 home-modules-section">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <h2 class="mt-3 text-[1.6875rem] font-black tracking-tight text-white">
            Módulos principais
          </h2>

          <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-400">
            Instale, configure e mantenha o Linux com módulos independentes.
          </p>
        </div>
      </div>

      <div
        class="autom8-carousel-shell"
        data-carousel-shell
      >
        <button
          type="button"
          class="autom8-carousel-button autom8-carousel-button--prev"
          data-carousel-prev
          aria-label="Módulos anteriores"
          hidden
        >
          ‹
        </button>

        <div
          class="modules-carousel"
          data-carousel-viewport
        >
          {modules.slice(0, 9).map((item) => (
            <article class="modern-module-card">
              <div class="module-card-heading">
                <div
                  class="module-icon"
                  set:html={moduleIcons[item.slug] ?? moduleIcons.diagnose}
                ></div>

                <h3 class="text-[0.9375rem] font-black text-white">
                  {item.name}
                </h3>
              </div>

              <p class="mt-3 leading-7 text-slate-400">
                {item.description}
              </p>
            </article>
          ))}
        </div>

        <button
          type="button"
          class="autom8-carousel-button autom8-carousel-button--next"
          data-carousel-next
          aria-label="Próximos módulos"
          hidden
        >
          ›
        </button>
      </div>
    </div>
  </section>

    <section class="product-news-section px-6 pb-16 home-news-section">
    <div class="mx-auto max-w-7xl">
      <div class="product-news-heading">
        <h2>
          Acompanhe a evolução do AutoM8
        </h2>
      </div>

      <div class="product-news-grid">
        {productNews.map((news) => (
          <article class="product-news-item">
            <div class="product-news-item__body">
              <span class="product-news-item__category">
                {news.category}
              </span>

              <h3>
                {news.title}
              </h3>

              <p>
                {news.description}
              </p>
            </div>

            <a
              href={news.href}
              class="product-news-item__link"
              target={news.external ? '_blank' : undefined}
              rel={news.external ? 'noreferrer' : undefined}
            >
              <span>{news.linkLabel}</span>
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>










  <script>
    function setupAutom8Carousel(shell) {
      const viewport = shell.querySelector(
        '[data-carousel-viewport]'
      );
      const previousButton = shell.querySelector(
        '[data-carousel-prev]'
      );
      const nextButton = shell.querySelector(
        '[data-carousel-next]'
      );

      if (!viewport || !previousButton || !nextButton) {
        return;
      }

      const getStep = () => {
        const card = viewport.firstElementChild;

        if (!card) {
          return viewport.clientWidth;
        }

        const styles = window.getComputedStyle(viewport);
        const gap = Number.parseFloat(
          styles.columnGap || styles.gap || '20'
        );

        return card.getBoundingClientRect().width + gap;
      };

      const updateButtons = () => {
        const hasOverflow =
          viewport.scrollWidth > viewport.clientWidth + 2;

        const atStart = viewport.scrollLeft <= 2;

        const atEnd =
          viewport.scrollLeft + viewport.clientWidth >=
          viewport.scrollWidth - 2;

        shell.classList.toggle(
          'autom8-carousel-shell--overflow',
          hasOverflow
        );

        previousButton.hidden = !hasOverflow || atStart;
        nextButton.hidden = !hasOverflow || atEnd;
      };

      previousButton.addEventListener('click', () => {
        viewport.scrollBy({
          left: -getStep(),
          behavior: 'smooth'
        });
      });

      nextButton.addEventListener('click', () => {
        viewport.scrollBy({
          left: getStep(),
          behavior: 'smooth'
        });
      });

      viewport.addEventListener('scroll', updateButtons, {
        passive: true
      });

      window.addEventListener('resize', updateButtons);

      if ('ResizeObserver' in window) {
        const observer = new ResizeObserver(updateButtons);
        observer.observe(viewport);
      }

      window.requestAnimationFrame(updateButtons);
    }

    document
      .querySelectorAll('[data-carousel-shell]')
      .forEach(setupAutom8Carousel);
  </script>

  <script define:vars={{ terminalSessions }}>
    const screen = document.querySelector('[data-terminal-screen]');
    const sessions = terminalSessions;

    const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

    function addLine(text, type = 'plain') {
      const line = document.createElement('div');
      line.className = `live-terminal-line terminal-${type}`;
      line.textContent = text;
      screen.appendChild(line);
      screen.scrollTop = screen.scrollHeight;
    }

    async function typeCommand(command) {
      const line = document.createElement('div');
      line.className = 'live-terminal-line terminal-command-line';

      const prompt = document.createElement('span');
      prompt.className = 'terminal-prompt';
      prompt.textContent = 'user@linux:~$ ';

      const typed = document.createElement('span');
      typed.className = 'terminal-typed is-typing';

      line.appendChild(prompt);
      line.appendChild(typed);
      screen.appendChild(line);

      for (const char of command) {
        typed.textContent += char;
        await sleep(42 + Math.random() * 30);
      }

      typed.classList.remove('is-typing');
      screen.scrollTop = screen.scrollHeight;
    }

    async function runTerminal() {
      let index = 0;

      while (true) {
        const session = sessions[index % sessions.length];
        screen.innerHTML = '';

        await typeCommand(session.command);
        await sleep(700);

        for (const item of session.output) {
          addLine(item.text, item.type);
          await sleep(380);
        }

        await sleep(4800);
        index += 1;
      }
    }

    if (screen && Array.isArray(sessions)) {
      runTerminal();
    }
  </script>



</BaseLayout>
