];


const statIcons: Record<string, string> = {
  version: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4V5Zm2 2v10h12V7H6Zm2 2h4v2H8V9Zm0 4h8v2H8v-2Z"/></svg>`,
  apps: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z"/></svg>`,
  categories: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h8v6H3V5Zm10 0h8v6h-8V5ZM3 13h8v6H3v-6Zm10 0h8v6h-8v-6Z"/></svg>`,
  profiles: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5Z"/></svg>`
};

const carouselIcons: Record<string, string> = {
  workflow: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 3h6v6H5V3Zm8 12h6v6h-6v-6ZM7 11h2v3a3 3 0 0 0 3 3h1v2h-1a5 5 0 0 1-5-5v-3Zm6-4h2v4a3 3 0 0 1-3 3h-1v-2h1a1 1 0 0 0 1-1V7Z"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 20 5v6c0 5-3.4 9.4-8 11-4.6-1.6-8-6-8-11V5l8-3Zm0 2.2L6 6.45V11c0 3.85 2.42 7.28 6 8.82 3.58-1.54 6-4.97 6-8.82V6.45l-6-2.25Zm-1 4.8h2v4h-2V9Zm0 6h2v2h-2v-2Z"/></svg>`,
  audience: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.31 0-6 1.79-6 4v2h12v-2c0-2.21-2.69-4-6-4Zm8-1a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-.75 0-1.46.1-2.1.28A5.2 5.2 0 0 1 17 19v1h5v-1c0-2.21-2.24-4-5-4Z"/></svg>`,
  linux: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2c3 0 5 2.7 5 6 0 1.3-.3 2.5-.8 3.5 1.7 1.5 2.8 3.7 2.8 6.5H5c0-2.8 1.1-5 2.8-6.5A7.4 7.4 0 0 1 7 8c0-3.3 2-6 5-6Zm-2 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm4 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm-4.5 2.5c.7.7 1.6 1 2.5 1s1.8-.3 2.5-1L13 10h-2l-1.5.5Z"/></svg>`
