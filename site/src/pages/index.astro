    category: 'Release',
    title: `AutoM8 ${catalogSummary.version} já está disponível`,
    description: 'Conheça as mudanças, correções e melhorias incluídas na versão atual do produto.',
    href: '/changelog',
    linkLabel: 'Ler novidades',
    external: false
  },
  {
    category: 'Catálogo',
    title: `${catalogSummary.appsCount} aplicativos organizados em ${catalogSummary.categories.length} categorias`,
    description: 'Explore as ferramentas disponíveis para desenvolvimento, produtividade, servidores e uso diário.',
    href: '/modules',
    linkLabel: 'Explorar módulos',
    external: false
  },
  {
    category: 'Comunidade',
    title: 'Ajude a definir os próximos recursos',
    description: 'Envie sugestões, relate problemas e participe da evolução do AutoM8 pelo GitHub.',
    href: 'https://github.com/mdmjunior/autom8/issues',
    linkLabel: 'Participar',
    external: true
  }
