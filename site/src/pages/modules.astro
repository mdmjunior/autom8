---
import BaseLayout from '../layouts/BaseLayout.astro';
import modules from '../data/modules.json';
---

<BaseLayout title="Módulos · AutoM8">
  <section class="px-6 py-20">
    <div class="mx-auto max-w-7xl">
      <h1 class="text-4xl font-black text-white">Módulos</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
        O AutoM8 é dividido em módulos para manter segurança, clareza e evolução independente.
      </p>

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {modules.map((item) => (
          <article class="rounded-2xl border border-slate-700/80 bg-slate-900/50 p-6">
            <div class="mb-4 text-sm font-bold uppercase tracking-widest text-blue-300">{item.slug}</div>
            <h2 class="text-xl font-bold text-white">{item.name}</h2>
            <p class="mt-3 leading-7 text-slate-400">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
