---
import BaseLayout from '../layouts/BaseLayout.astro';
import roadmap from '../data/roadmap.json';
---

<BaseLayout title="Roadmap · AutoM8">
  <section class="px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h1 class="text-4xl font-black text-white">Roadmap</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
        Planejamento inicial por versão.
      </p>

      <div class="mt-10 space-y-6">
        {roadmap.map((release) => (
          <article class="rounded-2xl border border-slate-700/80 bg-slate-900/50 p-6">
            <div class="text-sm font-bold text-blue-300">{release.version}</div>
            <h2 class="mt-2 text-2xl font-black text-white">{release.title}</h2>
            <ul class="mt-5 grid gap-3 text-slate-300 md:grid-cols-2">
              {release.items.map((item) => (
                <li class="rounded-xl border border-slate-800 bg-slate-950/50 px-4 py-3">{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
