---
import BaseLayout from '../layouts/BaseLayout.astro';
import changelog from '../data/changelog.json';
---

<BaseLayout title="Changelog · AutoM8">
  <section class="px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h1 class="text-4xl font-black text-white">Changelog</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
        Histórico versionado do AutoM8.
      </p>

      <div class="mt-10 space-y-6">
        {changelog.map((release) => (
          <article class="rounded-2xl border border-slate-700/80 bg-slate-900/50 p-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h2 class="text-2xl font-black text-white">{release.version}</h2>
              <span class="rounded-full border border-blue-400/30 bg-blue-500/10 px-4 py-2 text-sm text-blue-200">
                {release.date}
              </span>
            </div>
            <ul class="mt-5 list-disc space-y-2 pl-5 text-slate-300">
              {release.changes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
